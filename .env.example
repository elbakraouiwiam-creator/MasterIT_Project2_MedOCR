# Medication Box Recognition API - Environment Variables
# Copy this file to .env and adjust values

# API Settings
DEBUG=False

# OCR Settings
# Path to Tesseract executable (leave empty to use system PATH)
# TESSERACT_CMD=/usr/bin/tesseract

# Matching Settings
FUZZY_MATCH_THRESHOLD=60
TOP_N_RESULTS=5

# Database
PRODUCTS_DB_PATH=data/produits.json
